# Required
# Database is managed by pf-db (shared with pf-payroll).
# Run `make db-up` in the pf-db repo before starting this service.
FINANCIAL_DATA_DATABASE_URL=postgresql+asyncpg://pf_db:pf_db@localhost:5432/pf_db
FINANCIAL_DATA_API_KEY=change-me-before-use

# Tooling — corporate pip/npm registries (used by make install/check on VPN)
CORPORATIVE_PIP_INDEX=https://pypi.ci.artifacts.corporative.com/artifactory/api/pypi/pythonhosted-pypi-release-remote/simple
CORPORATIVE_NPM_REGISTRY=https://npm.ci.artifacts.corporative.com/artifactory/api/npm/external-npm
CORPORATIVE_PROXY=http://sysproxy.corpo-rative.com:8080

# Optional — provider timeouts and base URLs
FINANCIAL_DATA_RATE_PROVIDER_TIMEOUT_SECONDS=10
FINANCIAL_DATA_MINDICADOR_BASE_URL=https://mindicador.cl/api
FINANCIAL_DATA_SII_BASE_URL=https://www.sii.cl
FINANCIAL_DATA_BCCH_API_BASE_URL=https://si3.bcentral.cl/SieteRestWS/SieteRestWS.ashx

# Optional — BCCH credentials (leave blank to disable)
FINANCIAL_DATA_BCCH_API_USER=
FINANCIAL_DATA_BCCH_API_PASSWORD=

# Optional — BCCH series codes
FINANCIAL_DATA_BCCH_SERIES_UF=
FINANCIAL_DATA_BCCH_SERIES_USD=
FINANCIAL_DATA_BCCH_SERIES_EUR=
FINANCIAL_DATA_BCCH_SERIES_UTM=
FINANCIAL_DATA_BCCH_SERIES_IPC_CL=
